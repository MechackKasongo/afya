# JWT (tous les services + BFF) — ≥ 64 caractères UTF-8
JWT_ACCESS_SECRET=dev-access-secret-at-least-64-characters-long-for-hs512-signing-key
JWT_REFRESH_SECRET=dev-refresh-secret-at-least-64-characters-long-for-hs512-signing-key

# API Gateway → BFF (conteneur gateway, fichier docker-compose.yml)
BFF_UPSTREAM=http://host.docker.internal:8080
# TLS auto-signé : ./scripts/generate-tls-certs.sh puis ports 8090 (HTTP) et 8443 (HTTPS)

# Stack full conteneurisée : ./scripts/stack-up.sh (docker-compose.stack.yml)
# UI http://127.0.0.1:8088 — BFF_UPSTREAM=http://bff:8080 dans ce compose

# Front Vite : cible du proxy /api (gateway par défaut depuis phase E)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8090
# Sans gateway : VITE_API_PROXY_TARGET=http://127.0.0.1:8080

# Stockage documents cliniques
# STORAGE_PROVIDER=filesystem
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=minio
# MINIO_SECRET_KEY=minio123
# MINIO_BUCKET=afya-clinical

# Audit
AUDIT_ENABLED=true
AUDIT_INGESTION_KEY=dev-audit-ingestion-key

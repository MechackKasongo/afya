@startuml MD02_UserService
title Modèle du domaine — User Service (MD-02)

skinparam classBackgroundColor #D6EAF8
skinparam classBorderColor #1A5276
skinparam classArrowColor #1A5276
skinparam classFontStyle bold

class Utilisateur {
  - id : Integer
  - nom : String
  - prenom : String
  - identifiant : String
  - email : String
  - telephone : String
  - dateCreation : Date
  - statut : {ACTIF, INACTIF}
}

class Role {
  - id : Integer
  - libelle : {ADMIN, MEDECIN, RECEPTIONNISTE, INFIRMIERE, LABORANTIN}
  - description : String
}

class Affectation {
  - id : Integer
  - utilisateurId : Integer
  - serviceHospitalierId : Integer
  - dateDebut : Date
  - dateFin : Date
  - statut : {EN_COURS, TERMINEE}
}

class JournalAction {
  - id : Integer
  - utilisateurId : Integer
  - action : String
  - entiteConcernee : String
  - dateHeure : DateTime
}

Utilisateur "0..*" -- "1" Role : possède >
Utilisateur "1" -- "0..*" Affectation : a >
Utilisateur "1" -- "0..*" JournalAction : génère >

@enduml

@startuml CAS_UTILISATION_AFYA
title "Diagramme de cas d'utilisation — plateforme Afya (suivi patient, multi-services)"
skinparam usecaseStereotypeFontSize 11
skinparam actorStyle awesome
skinparam rectangleFontStyle bold

left to right direction

actor "Administrateur\n(Admin)" as Admin
actor "Réceptionniste" as Reception
actor "Médecin" as Medecin
actor "Infirmier(ère)" as Infirmier

rectangle "Système d'information hospitalier Afya" {

  package "Identité et sécurité" {
    (Authentification) as UC_Auth
  }

  package "Administration SI" {
    (Gérer les comptes utilisateurs) as UC_Users
    (Gérer départements et\nservices hospitaliers) as UC_Catalog
    (Consulter rapports et statistiques) as UC_Reports
    (Consulter le journal d'activité) as UC_Audit
  }

  package "Patient" {
    (Enregistrer un patient) as UC_RegPatient
    (Rechercher un patient) as UC_SearchPatient
  }

  package "Hospitalisation et parcours" {
    (Enregistrer l'admission) as UC_Adm
    (Affecter un patient à un service) as UC_AssignSvc
    (Gérer les transferts administratifs) as UC_Transfer
    (Consulter l'historique des admissions) as UC_HistAdm
    (Décider du transfert ou de la sortie du patient) as UC_Sortie
  }

  package "Dossier médical et soins" {
    (Consulter le dossier médical du patient) as UC_DMR
    (Ajouter diagnostics et observations) as UC_Diagnostics
    (Enregistrer les prescriptions) as UC_Prescriptions
    (Consulter les prescriptions) as UC_ReadRx
    (Enregistrer les soins infirmiers) as UC_Soins
    (Marquer l'exécution) as UC_Exec
    (Consulter l'historique des interventions) as UC_HistSoins
  }
}

' --- Tous les acteurs : authentification
Admin --> UC_Auth
Reception --> UC_Auth
Medecin --> UC_Auth
Infirmier --> UC_Auth

' --- Admin
Admin --> UC_Users
Admin --> UC_Catalog
Admin --> UC_Reports
Admin --> UC_Audit

' --- Réceptionniste
Reception --> UC_RegPatient
Reception --> UC_SearchPatient
Reception --> UC_Adm
Reception --> UC_AssignSvc
Reception --> UC_Transfer
Reception --> UC_HistAdm

' --- Médecin
Medecin --> UC_DMR
Medecin --> UC_Diagnostics
Medecin --> UC_Prescriptions
Medecin --> UC_Sortie

' --- Infirmier(ère)
Infirmier --> UC_SearchPatient
Infirmier --> UC_DMR
Infirmier --> UC_ReadRx
Infirmier --> UC_Soins
Infirmier --> UC_Exec
Infirmier --> UC_HistSoins

' --- Dépendances de type inclusion (UML)
UC_Adm ..> UC_RegPatient : <<include>>
UC_DMR ..> UC_SearchPatient : <<include>>

@enduml

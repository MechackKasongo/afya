@startuml CLASSES_PARTICIPANTES_PATIENT
title "Classes participantes — Enregistrer un patient"
skinparam classAttributeIconSize 0

actor Receptionniste as Rec

class PatientsPage <<boundary>> {
  - searchQuery : string
  - patients : PatientResponse[]
  - createForm : PatientCreateRequest
  --
  + search() : void
  + submitCreate() : void
  + openDetail(id) : void
}

class PatientBffController <<boundary>> {
  - patientClient : PatientClient
  --
  + search(query, page, size) : Page~PatientResponse~
  + getById(id) : PatientResponse
  + create(request) : PatientResponse
  + update(id, request) : PatientResponse
}

class PatientController <<boundary>> {
  - patientRegistryService : PatientRegistryService
  --
  + create(request) : PatientResponse
  + getById(id) : PatientResponse
  + search(query, page, size, sortBy, sortDir) : Page~PatientResponse~
  + update(id, request) : PatientResponse
}

class PatientRegistryService <<control>> {
  - patientRepository : PatientRepository
  - dossierSequenceRepository : PatientDossierSequenceRepository
  - auditEventPublisher : AuditEventPublisher
  --
  + create(request) : PatientResponse
  + getById(id) : PatientResponse
  + search(...) : Page~PatientResponse~
  + update(id, request) : PatientResponse
  - generateDossierNumber() : String
}

class Patient <<entity>> {
  - id : Long
  - firstName : String
  - lastName : String
  - dossierNumber : String
  - birthDate : LocalDate
  - sex : String
  - phone : String
  - email : String
  - createdAt : Instant
}

class PatientDossierSequence <<entity>> {
  - year : int
  - lastValue : long
}

Rec --> PatientsPage --> PatientBffController --> PatientController --> PatientRegistryService
PatientRegistryService --> Patient
PatientRegistryService --> PatientDossierSequence

@enduml

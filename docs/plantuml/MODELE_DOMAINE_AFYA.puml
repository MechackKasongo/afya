@startuml MODELE_DOMAINE_AFYA
title "Modèle du domaine Afya — classes, attributs et méthodes (aligné JPA)"
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

legend right
  Attributs et **méthodes publiques** des entités JPA.
  **FK intra-service** : association UML (ManyToOne).
  **Référence inter-service** : attribut Long (patientId, …).
  Enums : constantes sans méthode métier.
endlegend

package "identity-service" <<BoundedContext>> #E8F4FC {

  class AppUser <<AggregateRoot>> {
    - id : Long «PK»
    - username : String
    - email : String
    - fullName : String
    - passwordHash : String
    - active : boolean
    - createdAt : Instant
    - hospitalServiceIds : Set<Long>
    --
    + getId() : Long
    + getUsername() : String
    + setUsername(String) : void
    + getEmail() : String
    + setEmail(String) : void
    + getFullName() : String
    + setFullName(String) : void
    + getPasswordHash() : String
    + setPasswordHash(String) : void
    + getRoles() : Set<Role>
    + setRoles(Set<Role>) : void
    + getHospitalServiceIds() : Set<Long>
    + setHospitalServiceIds(Set<Long>) : void
    + isActive() : boolean
    + setActive(boolean) : void
    + getCreatedAt() : Instant
  }

  class Role <<Entity>> {
    - id : Long «PK»
    - code : String
    - label : String
    --
    + getId() : Long
    + getCode() : String
    + setCode(String) : void
    + getLabel() : String
    + setLabel(String) : void
  }

  class RefreshToken <<Entity>> {
    - id : Long «PK»
    - userId : Long «FK»
    - tokenHash : String
    - expiresAt : Instant
    - revoked : boolean
    - createdAt : Instant
    --
    + getId() : Long
    + getUser() : AppUser
    + setUser(AppUser) : void
    + getTokenHash() : String
    + setTokenHash(String) : void
    + getExpiresAt() : Instant
    + setExpiresAt(Instant) : void
    + isRevoked() : boolean
    + setRevoked(boolean) : void
  }

  class RevokedAccessJti <<Entity>> {
    - jti : String «PK»
    - expiresAt : Instant
    - revokedAt : Instant
    --
    + RevokedAccessJti()
    + RevokedAccessJti(String, Instant)
    + getJti() : String
    + getExpiresAt() : Instant
  }

  AppUser "1" o-- "*" RefreshToken : user
  AppUser "*" -- "*" Role : user_roles
}


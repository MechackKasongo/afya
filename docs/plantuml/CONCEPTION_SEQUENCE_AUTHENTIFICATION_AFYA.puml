@startuml CONCEPTION_SEQUENCE_AUTHENTIFICATION_AFYA
title "Diagramme de séquence de conception — Authentification (login)"
autonumber

actor Utilisateur as User
participant "SPA Web" as Web
participant "BFF" as BFF
participant "AuthController" as Ctrl
participant "AuthApplicationService" as Svc
participant "AppUserRepository" as Repo
participant "PasswordEncoder" as Enc
participant "JwtTokenIssuer" as Jwt
participant "RefreshSessionRepository" as RefreshRepo
participant "AuditEventPublisher" as Audit

User -> Web : saisie login / mot de passe
Web -> BFF : POST /api/v1/auth/login
BFF -> Ctrl : LoginRequest
Ctrl -> Svc : authenticate(username, password)

Svc -> Repo : findByUsername(username)
Repo --> Svc : Optional AppUser

alt utilisateur absent ou inactif
  Svc -> Audit : publish(LOGIN_FAILED)
  Svc --> Ctrl : UnauthorizedException
  Ctrl --> BFF : 401
  BFF --> Web : erreur
else utilisateur valide
  Svc -> Enc : matches(raw, hash)
  Enc --> Svc : boolean
  alt mot de passe incorrect
    Svc -> Audit : publish(LOGIN_FAILED)
    Svc --> Ctrl : 401
  else mot de passe correct
    Svc -> Jwt : issueAccessToken(user)
    Jwt --> Svc : accessToken
    Svc -> Jwt : issueRefreshToken(user)
    Jwt --> Svc : refreshToken
    Svc -> RefreshRepo : save(session)
    Svc -> Audit : publish(LOGIN_SUCCESS)
    Svc --> Ctrl : AuthResponse + MeResponse
    Ctrl --> BFF : 200
    BFF --> Web : tokens + profil
    Web --> User : redirection tableau de bord
  end
end

@enduml

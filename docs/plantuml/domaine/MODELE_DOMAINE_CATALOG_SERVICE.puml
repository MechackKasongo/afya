@startuml MODELE_DOMAINE_CATALOG_SERVICE
title "Modèle du domaine — catalog-service (BDD afya_catalog :5434)"
skinparam classAttributeIconSize 0
skinparam linetype ortho

database "PostgreSQL\nafya_catalog" as DB

package "afya_catalog" {

  class departments <<table>> {
    id : BIGINT «PK»
    code : VARCHAR(40) «UK»
    name : VARCHAR(120)
    active : BOOLEAN
    created_at : TIMESTAMP
  }

  class hospital_services <<table>> {
    id : BIGINT «PK»
    department_id : BIGINT «FK»
    name : VARCHAR(120) «UK»
    bed_capacity : INT
    beds_per_room : INT
    room_letter_prefix : CHAR(1)
    bed_assignment_policy : VARCHAR(32)
    active : BOOLEAN
    created_at : TIMESTAMP
  }

  class beds <<table>> {
    id : BIGINT «PK»
    hospital_service_id : BIGINT «FK»
    label : VARCHAR(40)
    occupied : BOOLEAN
    last_freed_at : TIMESTAMP
  }

  departments "1" *-- "1..*" hospital_services
  hospital_services "1" *-- "0..*" beds
}

departments --> DB
hospital_services --> DB
beds --> DB

class "identity-service\nuser_hospital_services" as ExtId <<external>>
ExtId ..> hospital_services : hospital_service_id

class "care-entry-service\nadmissions" as ExtCe <<external>>
ExtCe ..> hospital_services : hospital_service_id

@enduml

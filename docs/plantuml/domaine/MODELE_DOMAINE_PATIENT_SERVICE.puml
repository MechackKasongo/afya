@startuml MODELE_DOMAINE_PATIENT_SERVICE
title "Modèle du domaine — patient-service (BDD afya_patient :5435)"
skinparam classAttributeIconSize 0
skinparam linetype ortho

database "PostgreSQL\nafya_patient" as DB

package "afya_patient" {

  class patients <<table>> {
    id : BIGINT «PK»
    first_name : VARCHAR(80)
    last_name : VARCHAR(80)
    post_name : VARCHAR(120)
    dossier_number : VARCHAR(40) «UK»
    birth_date : DATE
    sex : VARCHAR(10)
    phone : VARCHAR(120)
    email : VARCHAR(120)
    address : VARCHAR(255)
    blood_group : VARCHAR(10)
    height_cm : DECIMAL(5,2)
    created_at : TIMESTAMP
    deceased_at : TIMESTAMP
  }

  class patient_dossier_sequences <<table>> {
    sequence_year : INT «PK»
    letter_block : VARCHAR(4)
    sequence_number : INT
  }

  class appointments <<table>> {
    id : BIGINT «PK»
    patient_id : BIGINT «FK»
    scheduled_at : TIMESTAMP
    status : VARCHAR(20)
    reason : VARCHAR(255)
    created_at : TIMESTAMP
  }

  patients "1" *-- "0..*" appointments
}

patients --> DB
patient_dossier_sequences --> DB
appointments --> DB

note right of appointments
  Hors périmètre BFF actuel
end note

class "care-entry\nadmissions" as ExtCe <<external>>
class "stay-service\nstays" as ExtSt <<external>>
class "clinical\nmedical_records" as ExtCl <<external>>

patients ..> ExtCe : patient_id
patients ..> ExtSt : patient_id
patients ..> ExtCl : patient_id

@enduml

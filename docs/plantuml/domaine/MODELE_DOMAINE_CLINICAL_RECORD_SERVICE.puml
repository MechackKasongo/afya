@startuml MODELE_DOMAINE_CLINICAL_RECORD_SERVICE
title "Modèle du domaine — clinical-record-service (BDD afya_clinical :5438)"
skinparam classAttributeIconSize 0
skinparam linetype ortho

database "PostgreSQL\nafya_clinical" as DB
storage "MinIO / filesystem" as Store

package "afya_clinical" {

  class medical_records <<table>> {
    id : BIGINT «PK»
    patient_id : BIGINT «UK»
    opened_at : TIMESTAMP
    allergies : VARCHAR(4000)
    antecedents : VARCHAR(16000)
  }

  class clinical_notes <<table>> {
    id : BIGINT «PK»
    medical_record_id : BIGINT «FK»
    authored_at : TIMESTAMP
    author_username : VARCHAR(80)
    narrative : VARCHAR(4000)
  }

  class diagnoses <<table>> {
    id : BIGINT «PK»
    medical_record_id : BIGINT «FK»
    code : VARCHAR(40)
    label : VARCHAR(255)
    recorded_at : TIMESTAMP
    author_username : VARCHAR(80)
  }

  class prescription_lines <<table>> {
    id : BIGINT «PK»
    medical_record_id : BIGINT «FK»
    drug_name : VARCHAR(120)
    dosage : VARCHAR(500)
    frequency : VARCHAR(80)
    start_date : DATE
    end_date : DATE
    status : VARCHAR(20)
    prescribed_by : VARCHAR(80)
    created_at : TIMESTAMP
  }

  class medication_administrations <<table>> {
    id : BIGINT «PK»
    prescription_line_id : BIGINT «FK»
    administered_at : TIMESTAMP
    dose_given : VARCHAR(80)
    nurse_username : VARCHAR(80)
    notes : VARCHAR(500)
  }

  class nursing_care_records <<table>> {
    id : BIGINT «PK»
    medical_record_id : BIGINT «FK»
    care_type : VARCHAR(80)
    performed_at : TIMESTAMP
    nurse_username : VARCHAR(80)
    description : VARCHAR(2000)
  }

  class clinical_documents <<table>> {
    id : BIGINT «PK»
    medical_record_id : BIGINT «FK»
    title : VARCHAR(200)
    content_type : VARCHAR(100)
    object_storage_key : VARCHAR(500)
    uploaded_at : TIMESTAMP
    uploaded_by : VARCHAR(80)
  }

  class consultations <<table>> {
    id : BIGINT «PK»
    patient_id : BIGINT
    admission_id : BIGINT
    doctor_name : VARCHAR(80)
    reason : VARCHAR(255)
    consultation_date_time : TIMESTAMP
  }

  class consultation_events <<table>> {
    id : BIGINT «PK»
    consultation_id : BIGINT «FK»
    patient_id : BIGINT
    event_type : VARCHAR(40)
    content : VARCHAR(4000)
    disease_type : VARCHAR(120)
    disease_name : VARCHAR(255)
    created_at : TIMESTAMP
  }

  class disease_catalog <<table>> {
    id : BIGSERIAL «PK»
    disease_type : VARCHAR(120)
    label : VARCHAR(255)
    label_normalized : VARCHAR(255)
    usage_count : INT
    first_used_at : TIMESTAMP
    last_used_at : TIMESTAMP
  }

  medical_records "1" *-- "0..*" clinical_notes
  medical_records "1" *-- "0..*" diagnoses
  medical_records "1" *-- "0..*" prescription_lines
  medical_records "1" *-- "0..*" nursing_care_records
  medical_records "1" *-- "0..*" clinical_documents
  consultations "1" *-- "0..*" consultation_events
  prescription_lines "1" *-- "0..*" medication_administrations
}

medical_records --> DB
clinical_documents ..> Store : object_storage_key

class "patient-service\npatients" as ExtPat <<external>>
class "care-entry-service\nadmissions" as ExtAdm <<external>>

medical_records ..> ExtPat : patient_id
consultations ..> ExtPat : patient_id
consultations ..> ExtAdm : admission_id

@enduml

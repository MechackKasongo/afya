@startuml ACTIVITE_PRISE_EN_CHARGE_MEDICALE_AFYA
title "Diagramme d'activité — Prise en charge médicale (médecin)"
|Médecin|
start
:Ouvrir Consultations ou dossier patient;
|Front / BFF|
:GET consultation + chronologie + dossier;
|clinical-record-service|
:Retourner Consultation, events, MedicalRecord;
|Médecin|
:Consulter antécédents / observations;
:Saisir diagnostic (type maladie + maladie + détails);
|Front / BFF|
:POST /consultations/{id}/diagnostics;
|clinical-record-service|
if (type et maladie présents ?) then (oui)
  :Enregistrer ConsultationEvent DIAGNOSTIC;
  :Incrémenter DiseaseCatalog;
  if (usageCount >= 5 ?) then (oui)
    :Maladie proposable au catalogue;
  endif
else (non)
  :Erreur 400;
  stop
endif
|Médecin|
:Prescrire traitement (fiche consultation);
|Front / BFF|
:POST /patients/{id}/prescriptions;
|clinical-record-service|
:Enregistrer PrescriptionLine;
|Médecin|
if (Décision finale ?) then (Hospitalisation / poursuite)
  :Formulaire clinique séjour si besoin;
  note right
    Patient déjà admis : suivi via
    admission + stay existants
  end note
else (Sortie)
  |Front / BFF|
  :POST /admissions/{id}/discharge;
  |care-entry-service|
  :Clôturer admission + séjour;
endif
:Confirmer mise à jour dossier;
stop
@enduml

@startuml ACTIVITE_SOIN_INFIRMIER_AFYA
title "Diagramme d'activité — Marquer l'exécution d'une prescription (infirmier·ère)"
|Infirmier(ère)|
start
:S'authentifier;
:Rechercher le patient;
|clinical-record-service|
:Charger le dossier et les prescriptions actives;
|Infirmier(ère)|
:Sélectionner une ligne de prescription;
if (Prescription valide et non exécutée ?) then (oui)
  :Saisir dose, heure, observations;
  |clinical-record-service|
  :Créer MedicationAdministration;
  :Mettre à jour le statut de la prescription si nécessaire;
  :Publier événement audit MEDICATION_ADMINISTERED;
  |Infirmier(ère)|
  :Afficher confirmation;
  stop
else (non)
  :Afficher message d'erreur métier;
  stop
endif

@enduml

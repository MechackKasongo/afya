@startuml ACTIVITE_GERER_UTILISATEURS_AFYA
title "Diagramme d'activité — Gérer les utilisateurs (administrateur)"
|Administrateur|
start
:Accéder au module Utilisateurs;
|Front / BFF|
:GET /api/v1/users (liste);
|identity-service|
:Charger utilisateurs + rôles;
|Administrateur|
if (Action ?) then (Ajouter)
  :Saisir informations + rôles;
  |Front / BFF|
  :POST /api/v1/users;
  |identity-service|
  if (Données valides ?) then (oui)
    :Hasher mot de passe + persister AppUser;
    :Audit USER_CREATED;
    :Confirmer création;
  else (non)
    :Afficher erreur validation;
  endif
elseif (Modifier) then
  :Sélectionner utilisateur;
  :Modifier champs / rôles / services;
  |Front / BFF|
  :PATCH /api/v1/users/{id};
  |identity-service|
  if (Valide ?) then (oui)
    :Mettre à jour + audit USER_UPDATED;
  else (non)
    :Erreur validation;
  endif
elseif (Supprimer / désactiver) then
  :Demander confirmation;
  if (Confirmé ?) then (oui)
    |Front / BFF|
    :DELETE ou désactivation;
    |identity-service|
    :Audit USER_DELETED / DEACTIVATED;
  else (non)
    :Annuler;
  endif
else (Consulter)
  :Afficher détail utilisateur;
endif
stop
@enduml

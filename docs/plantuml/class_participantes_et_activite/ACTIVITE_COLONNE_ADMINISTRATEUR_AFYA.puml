@startuml ACTIVITE_COLONNE_ADMINISTRATEUR_AFYA
title "Activité — colonne Administrateur"

|Administrateur|
start
:S'authentifier;

|identity-service|
:Valider identifiants;
:Générer session;

|Administrateur|
:Accéder à l'espace administration;

if (Action ?) then (Utilisateurs)
  :Ouvrir module Utilisateurs;
  |identity-service|
  :Gérer comptes et rôles;
  :Journaliser;
  |Administrateur|
  :Fin;
elseif (Services hospitaliers) then
  :Ouvrir module Services;
  |catalog-service|
  :Gérer catalogue et lits;
  :Journaliser;
  |Administrateur|
  :Fin;
elseif (Activités système) then
  :Ouvrir module Rapports;
  |audit-service|
  :Consulter journal et statistiques;
  |Administrateur|
  :Fin;
else (Consultation)
  :Consulter sans modification;
endif
stop
@enduml

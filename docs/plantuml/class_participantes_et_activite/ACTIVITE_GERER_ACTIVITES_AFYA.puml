@startuml ACTIVITE_GERER_ACTIVITES_AFYA
title "Diagramme d'activité — Gérer les activités du système (administrateur)"
|Administrateur|
start
:Accéder Reporting / Journal d'audit;
|Front / BFF|
fork
  :GET /api/v1/audit/events?page&filters;
fork again
  :GET /api/v1/reports/activity;
  :GET /api/v1/stats/volumes (option);
end fork
|audit-service|
:Récupérer AuditEvent paginés;
|Administrateur|
if (Données disponibles ?) then (oui)
  :Afficher tableau activités;
  :Appliquer filtres (date, action, acteur);
  |Front / BFF|
  :Requête filtrée;
  |audit-service|
  :Liste mise à jour;
  :Consulter détail d'un événement;
else (non)
  :Message « aucune activité »;
endif
stop
@enduml

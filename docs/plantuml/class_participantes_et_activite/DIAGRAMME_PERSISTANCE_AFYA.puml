@startuml DIAGRAMME_PERSISTANCE_AFYA
title "Diagramme de persistance — modèle des données (analyse, français)"
skinparam classAttributeIconSize 0
skinparam linetype ortho

legend right
  **Couche persistance uniquement** (entités / tables).
  Phase analyse — avant développement.
  --
  **Relations** :
  *-- composition (tout–partie)
  -- association (FK)
  ..> dépendance (inter-microservices)
  --
  **Tableau complet** (22 liens + cardinalités) :
  RELATIONS_UML_DIAGRAMMES.md § 2
endlegend

package "Identité et sécurité" #E8F4FC {

  class UtilisateurCompte <<entité>> {
    - identifiant : Entier {PK}
    - nomUtilisateur : Texte {UK}
    - nomComplet : Texte
    - courriel : Texte
    - motDePasseHaché : Texte
    - actif : Booléen
    - dateCreation : DateHeure
  }

  class Role <<entité>> {
    - identifiant : Entier {PK}
    - code : Texte {UK}
    - libelle : Texte
  }

  class UtilisateurRole <<entité>> {
    - identifiantUtilisateur : Entier {FK}
    - identifiantRole : Entier {FK}
  }

  class SessionUtilisateur <<entité>> {
    - identifiant : Entier {PK}
    - identifiantUtilisateur : Entier {FK}
    - jetonHaché : Texte
    - dateExpiration : DateHeure
    - revoque : Booléen
  }

  UtilisateurCompte "1" -- "0..*" UtilisateurRole : association
  Role "1" -- "0..*" UtilisateurRole : association
  UtilisateurCompte "1" -- "0..*" SessionUtilisateur : association
}

package "Catalogue hospitalier" #E8FCF0 {

  class Departement <<entité>> {
    - identifiant : Entier {PK}
    - code : Texte {UK}
    - nom : Texte
    - actif : Booléen
  }

  class ServiceHospitalier <<entité>> {
    - identifiant : Entier {PK}
    - identifiantDepartement : Entier {FK}
    - nom : Texte
    - description : Texte
    - capaciteLits : Entier
    - litsParChambre : Entier
    - actif : Booléen
  }

  class Lit <<entité>> {
    - identifiant : Entier {PK}
    - identifiantService : Entier {FK}
    - libelle : Texte
    - occupe : Booléen
    - dateLiberation : DateHeure
  }

  Departement "1" *-- "0..*" ServiceHospitalier : composition
  ServiceHospitalier "1" *-- "0..*" Lit : composition
}

package "Patient" #FFF8E8 {

  class Patient <<entité>> {
    - identifiant : Entier {PK}
    - numeroDossier : Texte {UK}
    - nom : Texte
    - prenom : Texte
    - dateNaissance : Date
    - sexe : Texte
    - telephone : Texte
    - courriel : Texte
    - dateCreation : DateHeure
    - dateDeces : DateHeure
  }

  class SequenceNumeroDossier <<entité>> {
    - annee : Entier {PK}
    - dernierNumero : Entier
  }
}

package "Parcours patient (admissions)" #FCE8F8 {

  class Admission <<entité>> {
    - identifiant : Entier {PK}
    - identifiantPatient : Entier {ref}
    - identifiantService : Entier {ref}
    - motif : Texte
    - typeAdmission : Texte
    - dateAdmission : DateHeure
    - dateSortie : DateHeure
    - statut : Texte
    - chambre : Texte
    - lit : Texte
  }

  class DemandeTransfert <<entité>> {
    - identifiant : Entier {PK}
    - identifiantAdmission : Entier {FK}
    - identifiantServiceOrigine : Entier {ref}
    - identifiantServiceDestination : Entier {ref}
    - dateDemande : DateHeure
  }

  class VisiteUrgence <<entité>> {
    - identifiant : Entier {PK}
    - identifiantPatient : Entier {ref}
    - dateArrivee : DateHeure
    - priorite : Texte
    - niveauTriage : Texte
    - statut : Texte
  }

  Admission "1" -- "0..*" DemandeTransfert : association
}

package "Séjour et hospitalisation" #F0E8FC {

  class Sejour <<entité>> {
    - identifiant : Entier {PK}
    - identifiantAdmission : Entier {ref, UK}
    - identifiantPatient : Entier {ref}
    - chambre : Texte
    - lit : Texte
    - dateEntree : DateHeure
    - dateSortie : DateHeure
    - statut : Texte
  }

  class FormulaireHospitalisation <<entité>> {
    - identifiantSejour : Entier {PK, FK}
    - motifConsultation : Texte
    - anamnese : Texte
    - allergies : Texte
    - dateMiseAJour : DateHeure
  }

  Sejour "1" *-- "0..1" FormulaireHospitalisation : composition
}

package "Dossier clinique" #FCEEE8 {

  class DossierMedical <<entité>> {
    - identifiant : Entier {PK}
    - identifiantPatient : Entier {ref, UK}
    - allergies : Texte
    - antecedents : Texte
    - dateOuverture : DateHeure

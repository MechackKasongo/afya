  class DocumentClinique <<entité>> {
    - identifiant : Entier {PK}
    - identifiantDossier : Entier {FK}
    - titre : Texte
    - typeContenu : Texte
    - cleStockage : Texte
    - dateDepot : DateHeure
  }

  DossierMedical "1" *-- "0..*" Diagnostic : composition
  DossierMedical "1" *-- "0..*" NoteClinique : composition
  DossierMedical "1" *-- "0..*" Prescription : composition
  DossierMedical "1" *-- "0..*" SoinInfirmier : composition
  DossierMedical "1" *-- "0..*" DocumentClinique : composition
  Consultation "1" *-- "0..*" EvenementConsultation : composition
  Prescription "1" -- "0..*" AdministrationMedicament : association
}

package "Audit et traçabilité" #EEEEEE {

  class JournalActivite <<entité>> {
    - identifiant : Entier {PK}
    - identifiantEvenement : UUID {UK}
    - dateEvenement : DateHeure
    - acteur : Texte
    - action : Texte
    - typeRessource : Texte
    - identifiantRessource : Texte
    - serviceSource : Texte
    - metadonnees : Texte
  }
}

' --- Liens logiques inter-contextes (références par identifiant) ---

Patient "1" ..> "0..*" Admission : dépendance
identifiantPatient
Patient "1" ..> "0..*" VisiteUrgence : dépendance
identifiantPatient
Patient "1" ..> "0..1" DossierMedical : dépendance
identifiantPatient
Patient "1" ..> "0..*" Consultation : dépendance
identifiantPatient
Patient "1" ..> "0..*" Sejour : dépendance
identifiantPatient

ServiceHospitalier "1" ..> "0..*" Admission : dépendance
identifiantService
Admission "1" ..> "0..1" Sejour : dépendance
identifiantAdmission
Admission "1" ..> "0..*" Consultation : dépendance
identifiantAdmission

@enduml

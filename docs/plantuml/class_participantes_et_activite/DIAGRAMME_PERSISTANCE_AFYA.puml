  class Consultation <<entité>> {
    - identifiant : Entier {PK}
    - identifiantPatient : Entier {ref}
    - identifiantAdmission : Entier {ref}
    - nomMedecin : Texte
    - motif : Texte
    - dateConsultation : DateHeure
  }

  class EvenementConsultation <<entité>> {
    - identifiant : Entier {PK}
    - identifiantConsultation : Entier {FK}
    - typeEvenement : Texte
    - contenu : Texte
    - typeMaladie : Texte
    - nomMaladie : Texte
    - dateCreation : DateHeure
  }

  class CatalogueMaladie <<entité>> {
    - identifiant : Entier {PK}
    - typeMaladie : Texte
    - libelle : Texte
    - libelleNormalise : Texte
    - nombreUtilisations : Entier
  }

  class Diagnostic <<entité>> {
    - identifiant : Entier {PK}
    - identifiantDossier : Entier {FK}
    - codeCIM : Texte
    - libelle : Texte
    - dateEnregistrement : DateHeure
  }

  class NoteClinique <<entité>> {
    - identifiant : Entier {PK}
    - identifiantDossier : Entier {FK}
    - auteur : Texte
    - contenu : Texte
    - dateRedaction : DateHeure
  }

  class Prescription <<entité>> {
    - identifiant : Entier {PK}
    - identifiantDossier : Entier {FK}
    - medicament : Texte
    - posologie : Texte
    - frequence : Texte
    - dateDebut : Date
    - dateFin : Date
    - statut : Texte
  }

  class SoinInfirmier <<entité>> {
    - identifiant : Entier {PK}
    - identifiantDossier : Entier {FK}
    - typeSoin : Texte
    - description : Texte
    - dateRealisation : DateHeure
    - infirmier : Texte

@startuml ACTIVITE_CAPACITES_ADMINISTRATEUR_AFYA
title "Diagramme d'activité côté Administrateur (SI Afya)"
' Vue menu (capacités). Détail : ACTIVITE_GERER_UTILISATEURS_AFYA, _SERVICES_HOSP_, _ACTIVITES_AFYA.

start
label authentification
:S'authentifier;
if (Authentification ?) then (Si échec)
  ->authentification;
else (Si réussie)
  :Choisir opération;
  fork
    :Logout;
    ->authentification;
  fork again
    :Gérer les comptes utilisateurs;
    if (Action ?) then (Créer)
      :Créer un compte utilisateur;
    elseif (Modifier) then
      :Modifier un compte utilisateur;
    elseif (Supprimer) then
      :Supprimer ou désactiver un compte;
    else (Consulter)
      :Consulter un utilisateur;
    endif
    :Choisir opération;
  fork again
    :Gérer les services hospitaliers;
    if (Action ?) then (Ajouter)
      :Ajouter un service;
    elseif (Modifier) then
      :Modifier un service;
    elseif (Supprimer) then
      :Supprimer un service;
    else (Consulter)
      :Consulter la grille des lits;
    endif
    :Choisir opération;
  fork again
    :Consulter rapports et statistiques;
    :Choisir opération;
  fork again
    :Consulter le journal d'activité;
    if (Données disponibles ?) then (oui)
      :Appliquer des filtres;
      :Consulter le détail d'un événement;
    else (non)
      :Afficher message aucune activité;
    endif
    :Choisir opération;
  end fork
endif
stop
@enduml

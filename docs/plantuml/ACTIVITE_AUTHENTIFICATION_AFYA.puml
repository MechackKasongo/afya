@startuml ACTIVITE_AUTHENTIFICATION_AFYA
title "Diagramme d'activité — Authentification (identity-service)"
|Utilisateur|
start
:Ouvrir l'application web;
:Saisir identifiant et mot de passe;
|Front / BFF|
:POST /api/v1/auth/login;
|identity-service|
:Valider le format de la requête;
if (Compte existant et actif ?) then (oui)
  if (Mot de passe correct ?) then (oui)
    :Générer access JWT et refresh token;
    :Persister la session refresh;
    :Publier événement audit LOGIN_SUCCESS;
    |Front / BFF|
    :Retourner tokens + profil utilisateur (me);
    |Utilisateur|
    :Accéder aux écrans selon le rôle;
    stop
  else (non)
    :Publier événement audit LOGIN_FAILED;
    :Réponse 401 Identifiants invalides;
    stop
  endif
else (non)
  :Réponse 401 Identifiants invalides;
  stop
endif

@enduml

@startuml CONCEPTION_CONSULTATION_AFYA
title "Conception — consultation et catalogue maladies (clinical-record-service)"
skinparam classAttributeIconSize 0

package "Présentation (REST)" {
  class ConsultationController {
    - consultationService : ConsultationService
    --
    + list(patientId, admissionId, page, size, sortBy, sortDir) : Page~ConsultationResponse~
    + getById(consultationId) : ConsultationResponse
    + consultationEvents(consultationId) : List~ConsultationEventResponse~
    + create(request, auth, httpRequest) : ConsultationResponse
    + addObservation(consultationId, request, auth) : ConsultationEventResponse
    + addDiagnostic(consultationId, request, auth) : ConsultationEventResponse
    + addExamOrder(consultationId, request, auth) : ConsultationEventResponse
  }
  class DiseaseCatalogController {
    - diseaseCatalogService : DiseaseCatalogService
    --
    + listSelectable(diseaseType) : List~DiseaseCatalogResponse~
  }
}

package "Application" {
  class ConsultationService {
    - consultationRepository : ConsultationRepository
    - consultationEventRepository : ConsultationEventRepository
    - medicalRecordRepository : MedicalRecordRepository
    - patientServiceClient : PatientServiceClient
    - careEntryServiceClient : CareEntryServiceClient
    - diseaseCatalogService : DiseaseCatalogService
    - auditEventPublisher : AuditEventPublisher
    --
    + create(request, username, authHeader) : ConsultationResponse
    + addDiagnostic(consultationId, request, username) : ConsultationEventResponse
    + addObservation(...) : ConsultationEventResponse
    + consultationEvents(consultationId) : List
    + patientTimeline(patientId) : List
  }
  class DiseaseCatalogService {
    - diseaseCatalogRepository : DiseaseCatalogRepository
    --
    + recordUsage(diseaseType, diseaseName) : void
    + listSelectable(diseaseType) : List~DiseaseCatalogResponse~
    + {static} normalizeLabel(label) : String
  }
}

package "Domaine / persistance" {
  class ConsultationRepository <<interface>> {
    + save(c) : Consultation
    + findById(id) : Optional~Consultation~
    + search(...) : Page~Consultation~
  }
  class ConsultationEventRepository <<interface>> {
    + save(e) : ConsultationEvent
    + findByConsultation_IdOrderByCreatedAtDesc(id) : List
  }
  class DiseaseCatalogRepository <<interface>> {
    + findByDiseaseTypeAndLabelNormalized(type, norm) : Optional
    + findByDiseaseTypeAndUsageCountGreaterThanEqual(...) : List
  }
  class Consultation {
    - id : Long
    - patientId : Long
    - admissionId : Long
    - doctorName : String
    - reason : String
    - consultationDateTime : Instant
  }
  class ConsultationEvent {
    - id : Long
    - eventType : ConsultationEventType
    - content : String
    - diseaseType : String
    - diseaseName : String
    - createdAt : Instant
  }
  class DiseaseCatalog {
    - id : Long
    - diseaseType : String
    - label : String
    - labelNormalized : String
    - usageCount : int
    --
    + isSelectable() : boolean
  }
}

ConsultationController --> ConsultationService
DiseaseCatalogController --> DiseaseCatalogService
ConsultationService --> ConsultationRepository
ConsultationService --> ConsultationEventRepository
ConsultationService --> DiseaseCatalogService
DiseaseCatalogService --> DiseaseCatalogRepository
ConsultationRepository --> Consultation
ConsultationEventRepository --> ConsultationEvent
DiseaseCatalogRepository --> DiseaseCatalog

@enduml

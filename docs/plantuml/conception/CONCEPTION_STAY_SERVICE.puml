@startuml CONCEPTION_STAY_SERVICE
title "Conception — stay-service (:8085)"
skinparam classAttributeIconSize 0

package "Présentation REST" {
  class StayController {
    + open(StayOpenRequest) : StayResponse
    + getById(Long) : StayResponse
    + getByAdmissionId(Long) : StayResponse
    + listByPatient(Long, ...) : Page<StayResponse>
    + close(Long) : StayResponse
    + closeByAdmissionId(Long) : StayResponse
    + upsertForm(Long, HospitalizationFormRequest) : HospitalizationFormResponse
    + getForm(Long) : HospitalizationFormResponse
  }
  class StayStatsController {
    + countOpenStays() : long
  }
}

package "Application" {
  class StayService {
    + open(StayOpenRequest, auth) : StayResponse
    + getById(Long, auth) : StayResponse
    + getByAdmissionId(Long, auth) : StayResponse
    + listByPatient(Long, ..., auth) : Page<StayResponse>
    + close(Long, auth) : StayResponse
    + closeByAdmissionId(Long, auth) : StayResponse
    + upsertForm(Long, HospitalizationFormRequest, auth) : HospitalizationFormResponse
    + getForm(Long, auth) : HospitalizationFormResponse
  }
}

package "Intégration HTTP" {
  class CareEntryServiceClient {
    + getAdmission(Long, auth) : AdmissionSummary
  }
  class PatientServiceClient {
    + getPatient(Long, auth) : PatientSummary
  }
}

package "Persistance" {
  interface StayRepository {
    + findByAdmissionId(Long) : Optional<Stay>
    + findById(Long) : Optional<Stay>
    + save(Stay) : Stay
  }
  interface HospitalizationFormRepository {
    + findByStayId(Long) : Optional<HospitalizationForm>
    + save(HospitalizationForm) : HospitalizationForm
  }
  class Stay <<Entity>> {
    - admissionId : Long
    - roomLabel : String
    - bedLabel : String
    - status : StayStatus
  }
  class HospitalizationForm <<Entity>> {
    - anamnesisText : String
    - antecedentsText : String
    - conclusionText : String
    --
    + getUpdatedAt() : Instant
    + setConclusionText(String) : void
  }
}

StayController --> StayService
StayService --> StayRepository
StayService --> HospitalizationFormRepository
StayService --> CareEntryServiceClient
StayService --> PatientServiceClient
StayRepository --> Stay
Stay "1" *-- "0..1" HospitalizationForm

@enduml

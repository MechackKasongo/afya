@startuml CONCEPTION_CLINICAL_RECORD_SERVICE
title "Conception — clinical-record-service (:8086)"
skinparam classAttributeIconSize 0

package "Présentation REST" {
  class MedicalRecordController {
    + getMedicalRecord(Long) : MedicalRecordResponse
    + updateAllergies(Long, ...) : MedicalRecordResponse
    + updateAntecedents(Long, ...) : MedicalRecordResponse
    + addNote(Long, ClinicalNoteRequest) : ClinicalNoteResponse
    + addDiagnosis(Long, DiagnosisRequest) : DiagnosisResponse
    + addPrescription(Long, PrescriptionRequest) : PrescriptionLineResponse
    + administer(Long, Long, ...) : MedicationAdministrationResponse
    + addNursingCare(Long, ...) : NursingCareResponse
    + uploadDocument(Long, MultipartFile) : ClinicalDocumentResponse
    + downloadDocument(Long, Long) : ResponseEntity
  }
  class ConsultationController {
    + list(...) : Page<ConsultationResponse>
    + getById(Long) : ConsultationResponse
    + create(ConsultationCreateRequest) : ConsultationResponse
    + addObservation(Long, ...) : ConsultationEventResponse
    + addDiagnostic(Long, ...) : ConsultationEventResponse
    + consultationEvents(Long) : List
  }
  class PrescriptionController {
    + listPrescriptions(Long, ...) : List
  }
  class DiseaseCatalogController {
    + listSelectable(String) : List<DiseaseCatalogResponse>
  }
}

package "Application" {
  class ClinicalRecordService {
    + getMedicalRecord(Long, auth, ...) : MedicalRecordResponse
    + updateAllergies(Long, ..., auth) : MedicalRecordResponse
    + addNote(Long, ..., username, auth) : ClinicalNoteResponse
    + addDiagnosis(Long, ..., username, auth) : DiagnosisResponse
    + addPrescription(Long, ..., username, auth) : PrescriptionLineResponse
    + administer(Long, Long, ..., nurse, auth) : MedicationAdministrationResponse
    + addNursingCare(Long, ..., nurse, auth) : NursingCareResponse
    + uploadDocument(Long, ..., auth) : ClinicalDocumentResponse
    + downloadDocument(Long, Long, auth) : DownloadedClinicalDocument
  }
  class ConsultationService {
    + list(...) : Page<ConsultationResponse>
    + create(..., username, auth) : ConsultationResponse
    + addDiagnostic(Long, ..., username) : ConsultationEventResponse
    + addObservation(Long, ..., username) : ConsultationEventResponse
    + consultationEvents(Long) : List
    + patientTimeline(Long) : List
  }
  class DiseaseCatalogService {
    + recordUsage(String, String) : void
    + listSelectable(String) : List
    + {static} normalizeLabel(String) : String
  }
}

package "Intégration" {
  class PatientServiceClient {
    + getPatient(Long, auth) : PatientSummary
  }
  class CareEntryServiceClient {
    + getAdmission(Long, auth) : AdmissionSummary
  }
  interface ObjectStorageService {
    + put(key, stream, contentType) : void
    + get(key) : InputStream
  }
  class MinioObjectStorageService
  class FilesystemObjectStorageService
}

package "Persistance" {
  interface MedicalRecordRepository {
    + findByPatientId(Long) : Optional<MedicalRecord>
  }
  interface ConsultationRepository
  interface ConsultationEventRepository
  interface PrescriptionLineRepository
  interface MedicationAdministrationRepository
  interface DiagnosisRepository
  interface ClinicalNoteRepository
  interface NursingCareRecordRepository
  interface ClinicalDocumentRepository
  interface DiseaseCatalogRepository
  class MedicalRecord <<Entity>>
  class Consultation <<Entity>>
  class ConsultationEvent <<Entity>>
  class PrescriptionLine <<Entity>>
  class DiseaseCatalog <<Entity>> {
    + isSelectable() : boolean
  }
}

MedicalRecordController --> ClinicalRecordService
ConsultationController --> ConsultationService
PrescriptionController --> ClinicalRecordService
DiseaseCatalogController --> DiseaseCatalogService
ClinicalRecordService --> MedicalRecordRepository
ClinicalRecordService --> ObjectStorageService
ConsultationService --> ConsultationRepository
ConsultationService --> DiseaseCatalogService
ConsultationService --> PatientServiceClient
ConsultationService --> CareEntryServiceClient
MedicalRecord "1" *-- "*" PrescriptionLine
Consultation "1" *-- "*" ConsultationEvent

@enduml

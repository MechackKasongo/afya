@startuml CONCEPTION_BDD_AFYA
title "Diagramme de conception — aligné schéma BDD (Flyway) + couches applicatives"
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
top to bottom direction

legend right
  **Persistance** : tables/colonnes = **MODELE_DOMAINE_BDD_AFYA.puml**.
  **Conception** : Controller → Service → Repository → Entité JPA.
  Méthodes issues du **code Java** actuel.
endlegend

package "identity-service → afya_identity" as IdSvc {

  package "Présentation" {
    class AuthController {
      + login(LoginRequest) : TokenResponse
      + refresh(RefreshRequest) : TokenResponse
      + logout(HttpServletRequest) : void
      + me(Authentication) : MeResponse
    }
    class UserController {
      + list(...) : Page<UserResponse>
      + create(UserCreateRequest) : UserResponse
      + update(Long, UserUpdateRequest) : UserResponse
      + delete(Long) : void
      + get(Long) : UserResponse
    }
  }

  package "Application" {
    class AuthService {
      + login(username, password) : TokenResponse
      + refresh(refreshToken) : TokenResponse
      + logout(accessToken, refreshToken) : void
      + me(Authentication) : MeResponse
    }
    class UserAdminService {
      + list(...) : Page<UserResponse>
      + create(UserCreateRequest) : UserResponse
      + update(Long, UserUpdateRequest) : UserResponse
      + delete(Long) : void
    }
    class JwtService {
      + issueAccessToken(AppUser) : String
      + issueRefreshToken(AppUser) : String
      + parseAccessToken(token) : Claims
    }
  }

  package "Persistance" {
    interface AppUserRepository {
      + findByUsernameIgnoreCase(String) : Optional<AppUser>
      + findById(Long) : Optional<AppUser>
    }
    interface RefreshTokenRepository {
      + findByTokenHash(String) : Optional<RefreshToken>
    }
    class app_users <<table>> {
      id, username, email, full_name
      password_hash, active, created_at
    }
    class user_roles <<table>>
    class refresh_tokens <<table>>
    class user_hospital_services <<table>>
  }

  AuthController --> AuthService
  UserController --> UserAdminService
  AuthService --> AppUserRepository
  AuthService --> RefreshTokenRepository
  AppUserRepository --> app_users
}

package "patient-service → afya_patient" as PatSvc {

  class PatientController {
    + create(PatientCreateRequest) : PatientResponse
    + getById(Long) : PatientResponse
    + search(...) : Page<PatientResponse>
    + update(Long, PatientUpdateRequest) : PatientResponse
    + declareDeath(Long, DeathDeclarationRequest) : PatientResponse
  }

  class PatientRegistryService {
    + create(PatientCreateRequest) : PatientResponse
    + getById(Long) : PatientResponse
    + search(...) : Page<PatientResponse>
    + update(Long, PatientUpdateRequest) : PatientResponse
    + declareDeath(Long, DeathDeclarationRequest) : PatientResponse
  }

  class DossierNumberGenerator {
    + generate() : String
  }

  interface PatientRepository {
    + findByDossierNumber(String) : Optional<Patient>
    + findById(Long) : Optional<Patient>
  }

  class patients <<table>> {
    id, dossier_number, first_name, last_name
    birth_date, deceased_at, ...
  }

  PatientController --> PatientRegistryService
  PatientRegistryService --> PatientRepository
  PatientRegistryService --> DossierNumberGenerator
  PatientRepository --> patients
}

package "catalog-service → afya_catalog" as CatSvc {

  class HospitalServiceController {
    + list(...) : Page
    + getById(Long) : HospitalServiceResponse
    + create(HospitalServiceRequest) : HospitalServiceResponse
    + update(Long, ...) : HospitalServiceResponse
  }

  class HospitalServiceCatalogService {
    + list(...) : Page
    + getById(Long) : HospitalServiceResponse
    + create(HospitalServiceRequest) : HospitalServiceResponse
    + update(Long, ...) : HospitalServiceResponse
    + delete(Long) : void
  }

  class CatalogStatsService {
    + occupancy() : OccupancyStatsResponse
    + suggestBed(Long) : BedSuggestionResponse
  }

  class BedService {
    + listByService(Long) : List<BedResponse>
    + updateOccupancy(Long, BedOccupancyRequest) : void
  }

  interface HospitalServiceRepository {
    + findById(Long) : Optional<HospitalService>
  }

  class hospital_services <<table>>
  class beds <<table>>
  class departments <<table>>

  HospitalServiceController --> HospitalServiceCatalogService
  HospitalServiceCatalogService --> HospitalServiceRepository
  HospitalServiceRepository --> hospital_services
  beds --> hospital_services : FK
}

package "care-entry-service → afya_care_entry" as CeSvc {

  class AdmissionController {
    + create(AdmissionCreateRequest) : AdmissionResponse
    + getById(Long) : AdmissionResponse
    + list(...) : Page
    + transfer(Long, TransferRequestDto) : AdmissionResponse
    + discharge(Long, DischargeRequest) : AdmissionResponse
    + cancel(Long) : AdmissionResponse
    + declareDeath(Long, DischargeRequest) : AdmissionResponse
  }

  class EmergencyController {
    + create(...) : EmergencyResponse
    + list(...) : Page
    + triage(Long, EmergencyTriageRequest) : EmergencyResponse
    + orient(Long, EmergencyOrientationRequest) : EmergencyResponse
    + close(Long) : EmergencyResponse
  }

  class VitalSignController {
    + record(Long admissionId, ...) : VitalSignResponse
    + listByAdmission(Long) : List
  }

  class AdmissionService {
    + admit(AdmissionCreateRequest, auth) : AdmissionResponse
    + getById(Long, auth) : AdmissionResponse
    + list(...) : Page
    + transfer(Long, TransferRequestDto, auth) : AdmissionResponse
    + discharge(Long, DischargeRequest, auth) : AdmissionResponse
    + declareDeath(Long, DischargeRequest, auth) : AdmissionResponse
    + cancel(Long, auth) : AdmissionResponse
  }

  class EmergencyVisitService {
    + create(...) : EmergencyResponse
    + list(...) : Page
    + applyTriage(...) : EmergencyResponse
    + applyOrientation(...) : EmergencyResponse
    + close(Long, auth) : EmergencyResponse
  }

  class VitalSignService {
    + record(Long admissionId, ...) : VitalSignResponse
    + listByAdmission(Long) : List
  }

  interface AdmissionRepository {
    + save(Admission) : Admission
    + findById(Long) : Optional
    + findByPatientIdOrderByAdmittedAtDesc(...) : Page
    + findByHospitalServiceIdInOrderByAdmittedAtDesc(...) : Page
    + existsByPatientIdAndStatusIn(...) : boolean
    + countByStatusIn(...) : long
  }

  class PatientServiceClient {
    + getPatient(Long, auth) : PatientSummary
  }
  class CatalogServiceClient {
    + getHospitalService(Long, auth) : HospitalServiceSummary
  }
  class StayServiceClient {
    + openStay(StayOpenRequest, auth) : StaySummary
  }

  class admissions <<table>> {
    patient_id, hospital_service_id
    status, admission_reason, ...
  }
  class transfer_requests <<table>>
  class emergency_visits <<table>>
  class vital_sign_readings <<table>>

  AdmissionController --> AdmissionService
  EmergencyController --> EmergencyVisitService
  VitalSignController --> VitalSignService
  AdmissionService --> AdmissionRepository
  AdmissionService --> PatientServiceClient
  AdmissionService --> CatalogServiceClient
  AdmissionService --> StayServiceClient
  AdmissionRepository --> admissions
  vital_sign_readings --> admissions : FK
}

package "stay-service → afya_stay" as StSvc {

  class StayController {
    + open(StayOpenRequest) : StayResponse
    + getById(Long) : StayResponse
    + getByAdmissionId(Long) : StayResponse
    + close(Long) : StayResponse
    + upsertForm(Long, HospitalizationFormRequest) : HospitalizationFormResponse
    + getForm(Long) : HospitalizationFormResponse
  }

  class StayService {
    + open(StayOpenRequest, auth) : StayResponse
    + getById(Long, auth) : StayResponse
    + getByAdmissionId(Long, auth) : StayResponse
    + listByPatient(Long, ...) : Page
    + close(Long, auth) : StayResponse
    + upsertForm(Long, request, auth) : HospitalizationFormResponse
    + getForm(Long, auth) : HospitalizationFormResponse
  }

  interface StayRepository {
    + findByAdmissionId(Long) : Optional<Stay>
    + findById(Long) : Optional<Stay>
  }

  class CareEntryServiceClient {
    + getAdmission(Long, auth) : AdmissionSummary
  }

  class stays <<table>>
  class hospitalization_forms <<table>>

  StayController --> StayService
  StayService --> StayRepository
  StayService --> CareEntryServiceClient
  StayRepository --> stays
  hospitalization_forms --> stays : FK
}

package "clinical-record-service → afya_clinical" as ClSvc {

  class MedicalRecordController {
    + getMedicalRecord(Long patientId) : MedicalRecordResponse
    + updateAllergies(...) : MedicalRecordResponse
    + addNote(...) : ClinicalNoteResponse
    + addPrescription(...) : PrescriptionLineResponse
    + uploadDocument(...) : ClinicalDocumentResponse
    + downloadDocument(...) : bytes
  }

  class ConsultationController {
    + list(...) : Page
    + create(ConsultationCreateRequest) : ConsultationResponse
    + addDiagnostic(...) : ConsultationEventResponse
    + consultationEvents(Long) : List
  }

  class ClinicalRecordService {
    + getMedicalRecord(Long, auth, ...) : MedicalRecordResponse
    + addNote(...) : ClinicalNoteResponse
    + addDiagnosis(...) : DiagnosisResponse
    + addPrescription(...) : PrescriptionLineResponse
    + administer(...) : MedicationAdministrationResponse
    + uploadDocument(...) : ClinicalDocumentResponse
    + downloadDocument(...) : DownloadedClinicalDocument
  }

  class ConsultationService {
    + list(...) : Page
    + create(...) : ConsultationResponse
    + addDiagnostic(...) : ConsultationEventResponse
    + consultationEvents(Long) : List
  }

  class DiseaseCatalogService {
    + recordUsage(diseaseType, diseaseName) : void
    + listSelectable(diseaseType) : List
  }

  interface MedicalRecordRepository {
    + findByPatientId(Long) : Optional<MedicalRecord>
  }
  interface ConsultationRepository {
    + findById(Long) : Optional<Consultation>
  }

  class PatientServiceClient {
    + getPatient(Long, auth) : PatientSummary
  }
  class CareEntryServiceClient {
    + getAdmission(Long, auth) : AdmissionSummary
  }

  class medical_records <<table>>
  class consultations <<table>>
  class consultation_events <<table>>
  class prescription_lines <<table>>
  class disease_catalog <<table>>

  MedicalRecordController --> ClinicalRecordService
  ConsultationController --> ConsultationService
  ClinicalRecordService --> MedicalRecordRepository
  ConsultationService --> ConsultationRepository
  ConsultationService --> PatientServiceClient
  ConsultationService --> CareEntryServiceClient
  prescription_lines --> medical_records : FK
}

package "audit-service → afya_audit" as AudSvc {

  class AuditEventController {
    + record(AuditEventCreateRequest) : AuditEventResponse
    + search(...) : Page
  }

  class ActivityReportController {
    + report(from, to) : ActivityReportResponse
  }

  class AuditEventService {
    + record(AuditEventCreateRequest) : AuditEventResponse
    + search(...) : Page<AuditEventResponse>
    + activityReport(Instant, Instant) : ActivityReportResponse
  }

  interface AuditEventRepository {
    + save(AuditEvent) : AuditEvent
    + findByOccurredAtBetween(...) : Page
  }

  class audit_events <<table>>

  AuditEventController --> AuditEventService
  ActivityReportController --> AuditEventService
  AuditEventService --> AuditEventRepository
  AuditEventRepository --> audit_events
}

package "afya-bff (agrégation)" as Bff {

  class AdmissionBffController {
    + create(...) : AdmissionResponse
    + list(...) : Page
    + suggestBed(serviceName) : BedSuggestionResponse
  }

  class PatientBffController {
    + search(...) : Page
    + create(...) : PatientResponse
  }

  class CareEntryClient {
    + createAdmission(...) : AdmissionResponse
    + listEmergencies(...) : Page
  }
  class PatientClient {
    + search(...) : Page
    + create(...) : PatientResponse
  }

  AdmissionBffController --> CareEntryClient
  PatientBffController --> PatientClient
}

note bottom of CeSvc
  Table **admissions** : patient_id et hospital_service_id
  sans FK SQL → validation via clients HTTP.
end note

@enduml

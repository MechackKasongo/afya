@startuml CONCEPTION_COUCHE_SERVICE_AFYA
title "Diagramme de classes de conception — care-entry-service (référence)"
skinparam classAttributeIconSize 0

package "Présentation (REST)" {
  class AdmissionController {
    + create(request) : AdmissionResponse
    + getById(id) : AdmissionResponse
    + list(patientId, status, page, size) : Page
    + transfer(id, dto) : AdmissionResponse
    + discharge(id, dto) : AdmissionResponse
    + cancel(id) : AdmissionResponse
    + declareDeath(id, dto) : AdmissionResponse
  }
  class EmergencyController {
    + create(request) : EmergencyResponse
    + list(...) : Page
    + triage(id, request) : EmergencyResponse
    + orient(id, request) : EmergencyResponse
    + close(id) : EmergencyResponse
  }
  class VitalSignController {
    + record(admissionId, request) : VitalSignResponse
    + listByAdmission(admissionId) : List
  }
  class CareEntryStatsController {
    + volumes() : PlatformVolumesResponse
  }
}

package "Application" {
  class AdmissionService {
    - admissionRepository : AdmissionRepository
    - transferRequestRepository : TransferRequestRepository
    - patientServiceClient : PatientServiceClient
    - catalogServiceClient : CatalogServiceClient
    - stayServiceClient : StayServiceClient
    - admissionWriter : AdmissionWriter
    - auditEventPublisher : AuditEventPublisher
    --
    + admit(request, authHeader) : AdmissionResponse
    + transfer(id, dto, authHeader) : AdmissionResponse
    + discharge(id, dto, authHeader) : AdmissionResponse
    + cancel(id, authHeader) : AdmissionResponse
    + declareDeath(id, dto, authHeader) : AdmissionResponse
    + getById(id, authHeader) : AdmissionResponse
    + list(...) : Page
  }
  class EmergencyVisitService
  class EmergencyVisitTimelineService
  class VitalSignService
  class AdmissionWriter {
    + persist(admission) : Admission
  }
  class AuthorizationHeaderSupport {
    + {static} requireBearer(request) : String
  }
}

package "Intégration (HTTP)" {
  class PatientServiceClient {
    + getPatient(patientId, auth) : PatientSummary
  }
  class CatalogServiceClient {
    + getHospitalService(id, auth) : HospitalServiceSummary
  }
  class StayServiceClient {
    + openStay(request, auth) : StaySummary
  }
  class PatientSummary <<DTO>>
  class HospitalServiceSummary <<DTO>>
  class StayOpenRequest <<DTO>>
  class StaySummary <<DTO>>
}

package "Persistance" {
  interface AdmissionRepository {
    + save(admission) : Admission
    + findById(id) : Optional
    + findByPatientId(...) : Page
  }
  interface TransferRequestRepository
  interface EmergencyVisitRepository
  interface VitalSignReadingRepository
  class Admission {
    - id : Long
    - patientId : Long
    - hospitalServiceId : Long
    - admittedAt : Instant
    - dischargedAt : Instant
    - status : AdmissionStatus
    - admissionReason : String
    - dischargeReason : String
    - createdAt : Instant
  }
  class TransferRequest {
    - admissionId : Long
    - fromServiceId : Long
    - toServiceId : Long
    - requestedAt : Instant
  }
  enum AdmissionStatus {
    OUVERTE
    TRANSFEREE
    SORTIE
    ANNULEE
  }
}

package "DTO (records)" {
  class AdmissionCreateRequest <<record>> {
    patientId : Long
    hospitalServiceId : Long
    admissionReason : String
    admittedAt : Instant
  }
  class AdmissionResponse <<record>>
  class TransferRequestDto <<record>>
  class DischargeRequest <<record>>
}

package "afya-shared (dépendances)" {
  interface AuditEventPublisher
  class HospitalScopeSupport
  class NotFoundException
  class ConflictException
}

AdmissionController --> AdmissionService
EmergencyController --> EmergencyVisitService
VitalSignController --> VitalSignService
AdmissionController ..> AuthorizationHeaderSupport
AdmissionService --> AdmissionRepository
AdmissionService --> TransferRequestRepository
AdmissionService --> PatientServiceClient
AdmissionService --> CatalogServiceClient
AdmissionService --> StayServiceClient
AdmissionService --> AdmissionWriter
AdmissionService --> AuditEventPublisher
AdmissionService ..> HospitalScopeSupport
AdmissionRepository --> Admission
Admission --> AdmissionStatus
AdmissionController ..> AdmissionCreateRequest : @Valid
AdmissionController ..> AdmissionResponse : retour

note right of AdmissionService
  **Conception** : une transaction JPA locale ;
  appels REST synchrones vers patient,
  catalog, stay ; audit HTTP via
  RestAuditEventPublisher.
end note

@enduml

@startuml CONCEPTION_SEQUENCE_PRISE_EN_CHARGE_AFYA
title "Diagramme de séquence de conception — Prise en charge médicale (consultation, diagnostic, prescription)"
autonumber

actor Médecin as Med
participant "SPA Web" as Web
participant "BFF" as BFF
participant "ConsultationController" as ConsCtrl
participant "ConsultationService" as ConsSvc
participant "DiseaseCatalogService" as CatSvc
participant "PrescriptionController" as RxCtrl
participant "ClinicalRecordService" as ClinSvc
participant "CareEntryServiceClient" as CEClient
database "BD clinical" as DB

== Ouvrir consultation ==
Med -> Web : fiche consultation
Web -> BFF : GET /consultations/{id}/events
BFF -> ConsCtrl : consultationEvents(id)
ConsCtrl -> ConsSvc : consultationEvents(id)
ConsSvc -> DB : SELECT events
DB --> Web : chronologie

== Diagnostic (type + maladie) ==
Med -> Web : saisir type, maladie, détails
Web -> BFF : GET /disease-catalog?diseaseType=…
BFF -> ConsCtrl : listSelectable(type)
ConsCtrl -> CatSvc : listSelectable(type)
CatSvc -> DB : usage_count >= 5
DB --> Web : suggestions datalist

Web -> BFF : POST /consultations/{id}/diagnostics
BFF -> ConsCtrl : EventCreateRequest
ConsCtrl -> ConsSvc : addDiagnostic()
ConsSvc -> CEClient : valider admission/patient
ConsSvc -> DB : INSERT consultation_event
ConsSvc -> CatSvc : recordUsage(type, name)
ConsSvc --> Web : 201 + diseaseType, diseaseName

== Prescription (fiche consultation) ==
Med -> Web : ajouter prescription
Web -> BFF : POST /patients/{id}/prescriptions
BFF -> RxCtrl : PrescriptionCreateRequest
RxCtrl -> ClinSvc : addPrescription()
ClinSvc -> DB : INSERT prescription_line
ClinSvc --> Web : 201

== Décision : sortie (option) ==
Med -> Web : clôturer admission
Web -> BFF : POST /admissions/{id}/discharge
BFF -> CEClient : discharge()
CEClient --> Web : admission SORTIE

@enduml

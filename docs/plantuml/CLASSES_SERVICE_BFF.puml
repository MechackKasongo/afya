@startuml CLASSES_SERVICE_BFF
title "Diagramme de classes — afya-bff (agrégation)"
skinparam classAttributeIconSize 0

package "Controllers REST" {
  class AuthBffController
  class UserBffController
  class PatientBffController
  class AdmissionBffController
  class EmergencyBffController
  class StayBffController
  class PatientClinicalBffController
  class ConsultationBffController
  class PrescriptionBffController
  class DiseaseCatalogBffController
  class HospitalServiceBffController
  class AuditBffController
  class StatsBffController
}

package "Clients HTTP" {
  class IdentityClient {
    + login(request) : TokenResponse
    + listUsers(...) : Page
  }
  class PatientClient {
    + search(...) : Page
    + create(request) : PatientResponse
  }
  class CareEntryClient {
    + createAdmission(request) : AdmissionResponse
    + listEmergencies(...) : Page
  }
  class StayClient {
    + openStay(request) : StayResponse
    + getForm(admissionId) : HospitalizationFormResponse
  }
  class ClinicalRecordClient {
    + getMedicalRecord(patientId) : MedicalRecordResponse
    + consultationEvents(id) : List
    + listSelectableDiseases(type) : List
  }
  class CatalogClient {
    + listHospitalServices() : List
    + occupancyStats() : CatalogOccupancyStatsResponse
  }
  class AuditClient {
    + listEvents(...) : Page
    + activityReport() : ActivityReportResponse
  }
}

AuthBffController "1" --> "1" IdentityClient : association
UserBffController "1" --> "1" IdentityClient : association
PatientBffController "1" --> "1" PatientClient : association
AdmissionBffController "1" --> "1" CareEntryClient : association
EmergencyBffController "1" --> "1" CareEntryClient : association
StayBffController "1" --> "1" StayClient : association
PatientClinicalBffController "1" --> "1" ClinicalRecordClient : association
ConsultationBffController "1" --> "1" ClinicalRecordClient : association
PrescriptionBffController "1" --> "1" ClinicalRecordClient : association
DiseaseCatalogBffController "1" --> "1" ClinicalRecordClient : association
HospitalServiceBffController "1" --> "1" CatalogClient : association
AuditBffController "1" --> "1" AuditClient : association
StatsBffController "1" --> "1" AuditClient : association
StatsBffController "1" --> "1" CareEntryClient : association
StatsBffController "1" --> "1" ClinicalRecordClient : association

legend right
  **Relations** : association (controller → client HTTP)
  Cardinalité : "1" → "1" par appel
  Transversal : X-Correlation-Id, timeout, retry, circuit-breaker
endlegend

@enduml

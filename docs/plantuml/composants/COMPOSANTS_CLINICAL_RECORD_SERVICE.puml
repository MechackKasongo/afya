@startuml COMPOSANTS_CLINICAL_RECORD_SERVICE
title "Diagramme de composants — clinical-record-service (:8086)"
skinparam componentStyle rectangle

actor "Client HTTP" as Client

package "clinical-record-service" {

  component "MedicalRecordController" as MrCtrl <<REST>>
  component "ConsultationController" as ConsCtrl <<REST>>
  component "PrescriptionController" as RxCtrl <<REST>>
  component "DiseaseCatalogController" as DisCtrl <<REST>>
  component "ClinicalStatsController" as StatsCtrl <<REST>>

  component "ClinicalRecordService" as MrSvc <<service>>
  component "ConsultationService" as ConsSvc <<service>>
  component "DiseaseCatalogService" as DisSvc <<service>>

  component "MedicalRecordRepository" as MrRepo <<repository>>
  component "ConsultationRepository" as ConsRepo <<repository>>
  component "ConsultationEventRepository" as EvRepo <<repository>>
  component "PrescriptionLineRepository" as RxRepo <<repository>>
  component "MedicationAdministrationRepository" as MedAdmRepo <<repository>>
  component "DiagnosisRepository" as DxRepo <<repository>>
  component "ClinicalNoteRepository" as NoteRepo <<repository>>
  component "NursingCareRecordRepository" as NcRepo <<repository>>
  component "ClinicalDocumentRepository" as DocRepo <<repository>>
  component "DiseaseCatalogRepository" as DisRepo <<repository>>

  component "PatientServiceClient" as PatClient <<integration>>
  component "CareEntryServiceClient" as CeClient <<integration>>

  interface "ObjectStorageService" as StorageAPI
  component "MinioObjectStorageService" as Minio <<storage>>
  component "FilesystemObjectStorageService" as Fs <<storage>>

  component "SecurityConfig" as SecCfg <<config>>
}

package "afya-shared" as Shared {
  component "HttpResilienceInterceptor" as Resilience
  component "RestAuditEventPublisher" as AuditPub
}

database "PostgreSQL\nafya_clinical :5438" as DB
storage "MinIO / filesystem\n:9000" as ObjStore

component "patient-service\n:8083" as Patient
component "care-entry-service\n:8084" as CareEntry
component "audit-service\n:8087" as Audit

Client --> MrCtrl
Client --> ConsCtrl
Client --> RxCtrl
Client --> DisCtrl
Client --> StatsCtrl

MrCtrl --> MrSvc
ConsCtrl --> ConsSvc
RxCtrl --> MrSvc
DisCtrl --> DisSvc
StatsCtrl --> MrRepo

MrSvc --> MrRepo
MrSvc --> RxRepo
MrSvc --> MedAdmRepo
MrSvc --> DxRepo
MrSvc --> NoteRepo
MrSvc --> NcRepo
MrSvc --> DocRepo
MrSvc --> PatClient
MrSvc --> StorageAPI
ConsSvc --> ConsRepo
ConsSvc --> EvRepo
ConsSvc --> PatClient
ConsSvc --> CeClient
ConsSvc --> DisSvc
DisSvc --> DisRepo

MrRepo --> DB
ConsRepo --> DB
EvRepo --> DB
RxRepo --> DB
DisRepo --> DB

Minio ..|> StorageAPI
Fs ..|> StorageAPI
StorageAPI --> ObjStore

PatClient ..> Patient
CeClient ..> CareEntry
PatClient ..> Resilience
CeClient ..> Resilience

MrSvc ..> AuditPub
ConsSvc ..> AuditPub
AuditPub ..> Audit

@enduml

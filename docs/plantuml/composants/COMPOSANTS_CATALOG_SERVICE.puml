@startuml COMPOSANTS_CATALOG_SERVICE
title "Diagramme de composants — catalog-service (:8082)"
skinparam componentStyle rectangle

actor "Client HTTP" as Client

package "catalog-service" {

  component "DepartmentController" as DeptCtrl <<REST>>
  component "HospitalServiceController" as HospCtrl <<REST>>
  component "BedController" as BedCtrl <<REST>>
  component "StatsController\n/occupancy, bed-suggestion" as StatsCtrl <<REST>>

  component "DepartmentService" as DeptSvc <<service>>
  component "HospitalServiceCatalogService" as HospSvc <<service>>
  component "BedService" as BedSvc <<service>>
  component "CatalogStatsService" as CatStats <<service>>
  component "BedAssignmentSelector" as BedSel <<service>>

  component "DepartmentRepository" as DeptRepo <<repository>>
  component "HospitalServiceRepository" as HospRepo <<repository>>
  component "BedRepository" as BedRepo <<repository>>

  component "SecurityConfig" as SecCfg <<config>>
}

package "afya-shared" as Shared {
  component "RestAuditEventPublisher" as AuditPub
}

database "PostgreSQL\nafya_catalog :5434" as DB

component "audit-service" as Audit

Client --> DeptCtrl
Client --> HospCtrl
Client --> BedCtrl
Client --> StatsCtrl

DeptCtrl --> DeptSvc
HospCtrl --> HospSvc
BedCtrl --> BedSvc
StatsCtrl --> CatStats

DeptSvc --> DeptRepo
HospSvc --> HospRepo
HospSvc --> BedSvc
BedSvc --> BedRepo
CatStats --> HospRepo
CatStats --> BedRepo
CatStats --> BedSel

DeptRepo --> DB
HospRepo --> DB
BedRepo --> DB

DeptSvc ..> AuditPub
HospSvc ..> AuditPub
AuditPub ..> Audit

note right of DB
  departments, hospital_services, beds
end note

@enduml

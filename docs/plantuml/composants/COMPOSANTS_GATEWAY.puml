@startuml COMPOSANTS_GATEWAY
title "Diagramme de composants — API Gateway (infra/gateway)"
skinparam componentStyle rectangle

actor "Navigateur\nSPA React" as Browser

package "Couche edge" {

  component "Serveur statique UI\nNginx frontend :8088" as WebUi <<nginx>>

  component "API Gateway\nNginx :8090 / :8443" as Gateway <<gateway>>

  note right of Gateway
    TLS optionnel (8443)
    Rate limiting
    Proxy /api/ → BFF
    Proxy /actuator/
    Aucune logique métier
  end note
}

package "afya-bff :8080" as BffPkg {
  component "afya-bff\nSpring Boot" as Bff <<BFF>>
}

Browser --> WebUi
Browser --> Gateway : HTTPS /api/v1
Gateway --> Bff : BFF_UPSTREAM\nhttp://bff:8080

@enduml

@startuml CLASSES_SERVICE_CATALOG
title "Diagramme de classes — catalog-service"
skinparam classAttributeIconSize 0

class DepartmentController {
  - departmentService : DepartmentService
  + list() : List
  + create(request) : DepartmentResponse
}
class HospitalServiceController {
  - hospitalServiceCatalogService : HospitalServiceCatalogService
  + list(activeOnly) : List
  + create(request) : HospitalServiceResponse
  + bedSuggestion(id) : BedSuggestionResponse
}
class BedController {
  - bedService : BedService
  + listByService(serviceId) : List
  + generateBeds(serviceId) : List
}
class DepartmentService {
  - departmentRepository : DepartmentRepository
}
class HospitalServiceCatalogService {
  - hospitalServiceRepository : HospitalServiceRepository
  - bedService : BedService
}
class BedService {
  - bedRepository : BedRepository
  - bedAssignmentSelector : BedAssignmentSelector
}
class Department {
  - id : Long
  - code : String
  - name : String
}
class HospitalService {
  - id : Long
  - name : String
  - bedCapacity : int
}
class Bed {
  - label : String
  - occupied : boolean
}

DepartmentController --> DepartmentService --> Department
HospitalServiceController --> HospitalServiceCatalogService --> HospitalService
BedController --> BedService --> Bed
HospitalService --> Department

@enduml

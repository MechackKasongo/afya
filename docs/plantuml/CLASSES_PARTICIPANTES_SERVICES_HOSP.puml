@startuml CLASSES_PARTICIPANTES_SERVICES_HOSP
title "Classes participantes — Gérer les services hospitaliers"
skinparam classAttributeIconSize 0

actor Administrateur as Admin

class HospitalServicesPage <<boundary>> {
  - departments : DepartmentResponse[]
  - services : HospitalServiceResponse[]
  --
  + loadCatalog() : void
  + saveService(form) : void
  + generateBeds(serviceId) : void
}

class HospitalServiceBffController <<boundary>> {
  - catalogClient : CatalogClient
  --
  + listDepartments() : List
  + listServices() : List
  + createService(request) : HospitalServiceResponse
  + updateService(id, request) : HospitalServiceResponse
}

class HospitalServiceController <<boundary>> {
  - hospitalServiceCatalogService : HospitalServiceCatalogService
  --
  + list(activeOnly) : List~HospitalServiceResponse~
  + getById(id) : HospitalServiceResponse
  + create(request) : HospitalServiceResponse
  + update(id, request) : HospitalServiceResponse
  + updateStatus(id, request) : void
}

class HospitalServiceCatalogService <<control>> {
  - hospitalServiceRepository : HospitalServiceRepository
  - bedService : BedService
  --
  + create(request) : HospitalServiceResponse
  + update(id, request) : HospitalServiceResponse
  + delete(id) : void
}

class Department <<entity>> {
  - id : Long
  - code : String
  - name : String
  - active : boolean
}

class HospitalService <<entity>> {
  - id : Long
  - department : Department
  - name : String
  - bedCapacity : int
  - bedsPerRoom : int
  - active : boolean
}

class Bed <<entity>> {
  - id : Long
  - label : String
  - occupied : boolean
}

Admin --> HospitalServicesPage --> HospitalServiceBffController --> HospitalServiceController
HospitalServiceController --> HospitalServiceCatalogService
HospitalServiceCatalogService --> HospitalService
HospitalService --> Department
HospitalServiceCatalogService --> Bed

@enduml
